# delta-bridge configuration — install as /Storage/delta-bridge.conf
broker_host  = 192.168.1.10
broker_port  = 1883
# broker_user = mqttuser
# broker_pass = mqttpass
topic_prefix = delta-bridge
# device_id left blank -> derived at runtime
poll_hz      = 1
log_level    = info
log_path     = /Storage/delta-bridge.log

# v0.3 write controls. Off by default; flip to true to expose
# number.set_current / switch.authorize / button.clear_faults in HA.
# write_enable = false

# v0.4 embedded web UI. Off by default. When web_enable=true the bridge
# listens on web_port (default 8080) and serves a one-page status +
# config UI. Auth is HTTP Basic; if web_user OR web_pass is empty,
# auth is DISABLED for first-boot setup (a warning prints at startup).
# Lock down both fields before exposing the bridge on a shared network.
# web_enable = false
# web_port   = 8080
# web_user   = admin
# web_pass   = changeme

# v0.5 custom RFID reader. Off by default so the stock /root/RFID daemon
# keeps owning /dev/ttyAMA4. Flip rfid_enable=true to take over — the bridge
# kills /root/RFID, polls for ISO14443A UIDs at rfid_poll_hz, and publishes
# scans to MQTT (sensor.last_uid + event.scan). UID is uppercase ASCII hex.
# No allowlist policy in the bridge — HA owns it.
# rfid_enable     = false
# rfid_port       = /dev/ttyAMA4
# rfid_kill_stock = true
# rfid_poll_hz    = 5
