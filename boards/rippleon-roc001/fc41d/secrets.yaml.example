wifi_ssid: "your-iot-ssid"
wifi_password: "your-iot-pass"

# OCPP 1.6-J Central System (SteVe / evcc / CitrineOS / Monta / ...).
# `ws://` for unencrypted dev, `wss://` for prod TLS.
ocpp_csms_url: "ws://csms.example.local:8887"
# Charge point identity registered against the CSMS.
ocpp_charge_point_id: "openevcharger-01"
