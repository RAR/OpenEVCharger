# Build artifacts
build/
build_*/
*.elf
*.bin
*.hex
*.map
*.lst

# But keep our gitkeeps
!recovery/.gitkeep
!third_party/**/.gitkeep

# Recovery backups (large binaries, regenerated locally)
recovery/*.bin
recovery/*.hex

# Editor
.vscode/
.clangd/
.cache/
compile_commands.json
*.swp

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc

# ESPHome FC41D firmware: build cache + per-checkout secrets
fc41d/.esphome/
fc41d/secrets.yaml
build_host/
tools/.ntc_peek_baseline.json
